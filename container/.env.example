# ══════════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - EJEMPLO PARA DESARROLLO
# ══════════════════════════════════════════════════════════════════════════════
#
# ⚠️  ADVERTENCIA: Este archivo contiene valores de ejemplo para desarrollo.
#                  Para producción, usa valores reales y seguros.
#
# Copia este archivo a `.env` y ajusta los valores según tu entorno.
# NUNCA commits el archivo `.env` real con secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Configuración del Backend Mock ──────────────────────────────────────────
# ⚠️  NOTA: El backend mock usa credenciales hardcodeadas (demo/password123)
#           Estas variables son solo para referencia en un backend real.

# URL del backend (mock en desarrollo, real en producción)
VITE_BACKEND_URL=http://localhost:8000

# Endpoints de la API
VITE_AUTH_ENDPOINT=/api/auth/login
VITE_CHAT_ENDPOINT=/api/chat/message

# ─── Configuración del Widget Frontend ───────────────────────────────────────

# Posición del widget en pantalla
# Opciones: top-left, top-right, bottom-left, bottom-right
VITE_WIDGET_POSITION=bottom-right

# Modo de visualización del widget
# Opciones: floating, embedded, fullscreen
VITE_WIDGET_MODE=floating

# Modo de visualización de bloques <tinker>
# Opciones: hidden, visible, expandable
VITE_TINKER_MODE=hidden

# ─── Personalización de Colores (Opcional) ───────────────────────────────────
# Valores hex CSS. Descomenta y ajusta según necesites.

# VITE_COLOR_PRIMARY=#1a1a2e    # Color principal
# VITE_COLOR_ACCENT=#e94560     # Color de acento (botones, enlaces)
# VITE_COLOR_SURFACE=#16213e    # Color de fondo de superficies
# VITE_COLOR_TEXT=#eaeaea       # Color de texto principal

# ─── Configuración del Backend (Para Referencia - Backend Real) ──────────────
# ⚠️  Estas variables NO son usadas por el backend mock actual.
#     Son solo para referencia en caso de implementar un backend real.

# PORT=8000                     # Puerto del servidor backend
# NODE_ENV=development          # Entorno: development, production
# CORS_ORIGIN=http://localhost:5173  # Origen permitido para CORS
# JWT_SECRET=your-secret-key-here   # Secreto para firmar JWT (backend real)
# DATABASE_URL=postgresql://...     # URL de conexión a base de datos

# ─── Credenciales de Desarrollo Mock (Hardcodeadas) ──────────────────────────
# ⚠️  ADVERTENCIA: El backend mock actual tiene estas credenciales hardcodeadas.
#     NO son leídas desde variables de entorno. Son públicas y solo para desarrollo.

# MOCK_USERNAME=demo            # Usuario demo (hardcodeado en código)
# MOCK_PASSWORD=password123     # Contraseña demo (hardcodeada en código)
# MOCK_USERNAME_ALT=user        # Usuario alternativo (hardcodeado)
# MOCK_PASSWORD_ALT=user123     # Contraseña alternativa (hardcodeada)

# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES RÁPIDAS:
# 1. cp .env.example .env
# 2. Ajusta los valores según tu entorno
# 3. NUNCA commit .env al repositorio
# ══════════════════════════════════════════════════════════════════════════════
