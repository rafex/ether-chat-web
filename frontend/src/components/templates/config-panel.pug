div.config-panel(role="region" aria-label="Configuracion del chat")
  div.config-panel__header
    span.config-panel__title Configuracion
    button.chat-header__btn(
      type="button"
      aria-label="Cerrar configuracion"
      data-action="close-config"
    )
      svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        line(x1="18" y1="6" x2="6" y2="18")
        line(x1="6" y1="6" x2="18" y2="18")
  div.config-panel__body
    div.config-panel__group
      span.config-panel__label Tema
      div.config-panel__row
        button.config-panel__theme-btn.config-panel__theme-btn--dark(
          type="button"
          data-theme="dark"
          aria-pressed="false"
          aria-label="Tema oscuro"
        ) Dark
        button.config-panel__theme-btn.config-panel__theme-btn--light(
          type="button"
          data-theme="light"
          aria-pressed="false"
          aria-label="Tema claro"
        ) Light
        button.config-panel__theme-btn.config-panel__theme-btn--rafex(
          type="button"
          data-theme="rafex"
          aria-pressed="false"
          aria-label="Tema Rafex"
        ) Rafex
    div.config-panel__group
      span.config-panel__label Posicion
      div.config-panel__row
        each pos in ['top-left', 'top-right', 'bottom-left', 'bottom-right']
          button.config-panel__position-btn(
            type="button"
            data-position=pos
            aria-pressed="false"
            aria-label=`Posicion ${pos}`
          )= pos
    div.config-panel__group
      span.config-panel__label Colores personalizados
      div.config-panel__color-inputs
        div.config-panel__color-row
          label.config-panel__color-label(for="input-color-primary") Fondo
          input.config-panel__color-input(
            type="color"
            id="input-color-primary"
            aria-label="Color de fondo principal"
          )
        div.config-panel__color-row
          label.config-panel__color-label(for="input-color-accent") Acento
          input.config-panel__color-input(
            type="color"
            id="input-color-accent"
            aria-label="Color de acento"
          )
        div.config-panel__color-row
          label.config-panel__color-label(for="input-color-surface") Superficie
          input.config-panel__color-input(
            type="color"
            id="input-color-surface"
            aria-label="Color de superficie"
          )
        div.config-panel__color-row
          label.config-panel__color-label(for="input-color-text") Texto
          input.config-panel__color-input(
            type="color"
            id="input-color-text"
            aria-label="Color de texto"
          )
    div.config-panel__group
      span.config-panel__label Razonamiento del agente
      div.config-panel__row
        each mode in ['hidden', 'visible', 'expandable']
          button.config-panel__position-btn(
            type="button"
            data-tinker=mode
            aria-pressed="false"
          )= mode
